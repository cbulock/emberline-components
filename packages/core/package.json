{
  "name": "emberline-ui-core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles.css"
  ],
  "sideEffects": [
    "./src/styles.css",
    "./dist/register.js",
    "./dist/register.cjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js",
      "require": "./dist/register.cjs"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsup src/index.ts src/register.ts --format esm,cjs --dts"
  },
  "dependencies": {
    "emberline-design-system": "github:cbulock/design-system",
    "lit": "^3.2.1"
  }
}
