{
  "name": "cindor-ui-core",
  "version": "0.1.10",
  "description": "Framework-agnostic Cindor web components built on standard custom elements.",
  "type": "module",
  "customElements": "./custom-elements.json",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles.css",
    "custom-elements.json",
    "component-docs.json"
  ],
  "sideEffects": [
    "./src/styles.css",
    "./dist/register.js",
    "./dist/register.cjs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cbulock/cindor",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/cbulock/cindor#readme",
  "bugs": {
    "url": "https://github.com/cbulock/cindor/issues"
  },
  "keywords": [
    "cindor",
    "web-components",
    "custom-elements",
    "lit",
    "design-system"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js",
      "require": "./dist/register.cjs"
    },
    "./styles.css": "./src/styles.css",
    "./custom-elements.json": "./custom-elements.json",
    "./component-docs.json": "./component-docs.json"
  },
  "scripts": {
    "build": "tsup src/index.ts src/register.ts --format esm,cjs --dts"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "cindor-design": "github:cbulock/cindor-design",
    "highlight.js": "^11.11.1",
    "lit": "^3.2.1",
    "lucide": "^1.11.0"
  }
}
