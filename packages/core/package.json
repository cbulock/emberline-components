{
  "name": "cindor-ui-core",
  "version": "0.1.0",
  "type": "module",
  "customElements": "./custom-elements.json",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles.css",
    "custom-elements.json",
    "component-docs.json"
  ],
  "sideEffects": [
    "./src/styles.css",
    "./dist/register.js",
    "./dist/register.cjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js",
      "require": "./dist/register.cjs"
    },
    "./styles.css": "./src/styles.css",
    "./custom-elements.json": "./custom-elements.json",
    "./component-docs.json": "./component-docs.json"
  },
  "scripts": {
    "build": "tsup src/index.ts src/register.ts --format esm,cjs --dts"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "cindor-design": "github:cbulock/cindor-design",
    "highlight.js": "^11.11.1",
    "lit": "^3.2.1",
    "lucide": "^1.11.0"
  }
}
