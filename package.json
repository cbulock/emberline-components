{
  "name": "cindor-ui-workspace",
  "version": "0.1.24",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run generate:manifest && npm run generate:wrappers && npm run build --workspace cindor-ui-core && npm run build --workspace cindor-ui-react && npm run build --workspace cindor-ui-vue && npm run build --workspace cindor-ui-docs",
    "build:docs": "npm run generate:manifest && npm run build --workspace cindor-ui-docs",
    "docs": "npm run generate:manifest && npm run dev --workspace cindor-ui-docs",
    "docs:preview": "npm run preview --workspace cindor-ui-docs",
    "generate:manifest": "node scripts/generate-component-manifest.mjs",
    "generate:wrappers": "node scripts/generate-framework-wrappers.mjs",
    "lint": "eslint .",
    "prepare": "simple-git-hooks",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test": "vitest run --project unit",
    "test:all": "vitest run --project unit --project storybook",
    "test:storybook": "vitest run --project storybook",
    "test:watch": "vitest --project unit",
    "test:one": "vitest run --project unit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "version:auto-bump": "node scripts/auto-version-bump.mjs"
  },
  "simple-git-hooks": {
    "pre-push": "npm run version:auto-bump"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^9.25.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/web-components-vite": "^10.3.5",
    "@types/node": "^24.9.1",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitest/browser": "^3.1.1",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.25.1",
    "eslint-plugin-storybook": "10.3.5",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "lit": "^3.2.1",
    "playwright": "^1.59.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.3.5",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^7.1.11",
    "vitest": "^3.1.1",
    "vue": "^3.5.13"
  },
  "customElements": "packages/core/custom-elements.json"
}
