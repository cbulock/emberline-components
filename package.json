{
  "name": "emberline-ui-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace emberline-ui-core && npm run build --workspace emberline-ui-react && npm run build --workspace emberline-ui-vue",
    "lint": "eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:one": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/web-components-vite": "^8.6.12",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "lit": "^3.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^8.6.12",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.1",
    "vue": "^3.5.13"
  }
}
